{
  "log": {
    "disabled": true
  },
  "dns": {
    "servers": [
      {
        "type": "local"
      }
    ],
    "strategy": "prefer_ipv6"
  },
  "ntp": {
    "enabled": true,
    "server": "time.apple.com",
    "server_port": 123,
    "interval": "60m"
  },
  "inbounds": [
    {
      "tag": "VMESS-WS",
      "type": "vmess",
      "listen": "::",
      "listen_port": 38438,
      "tcp_fast_open": false,
      "proxy_protocol": false,
      "users": [
        {
          "uuid": "e98847c9-8159-4265-8339-3912d6bfc176",
          "alterId": 0
        }
      ],
      "transport": {
        "type": "ws",
        "path": "/RuZp9iKjEzkYH8XLfNqnddsfEU9GZwVAhm8niFJj",
        "max_early_data": 2560,
        "early_data_header_name": "Sec-WebSocket-Protocol"
      },
      "multiplex": {
        "enabled": true,
        "padding": true,
        "brutal": {
          "enabled": false,
          "up_mbps": 1000,
          "down_mbps": 1000
        }
      }
    }
  ]
}
